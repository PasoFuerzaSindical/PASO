generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  password  String
  role      String       @default("user")
  createdAt DateTime     @default(now())

  // Relaciones
  bingo     BingoEntry[]
  posts     Post[]
}

model BingoEntry {
  id        String   @id @default(cuid())
  userId    String
  line      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
}

